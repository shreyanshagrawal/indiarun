# Database — paste your Supabase or Neon connection string here
# Format: postgresql+asyncpg://user:password@host:port/dbname
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Sync URL used by Alembic migrations (swap asyncpg → psycopg2)
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@host:5432/dbname

# Frontend origin for CORS
FRONTEND_URL=https://your-app.vercel.app

# LLM — free tier from Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# JWT secret — generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here
